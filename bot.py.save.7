from telegram import Update
from telegram.ext import Application, CommandHandler, MessageHandler, filters, ContextTypes

TOKEN = "7872471977:AAGu71rkVdC4FOjor95J_b6uBlvTlk88l1Y"

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("👋 سلام! به رزومه‌ساز هوشمند خوش اومدی!\n\nاطلاعات خودت رو بفرست (تحصیلات، تجربه، مهارت و...)")

async def make_resume(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("⏳ در حال ساخت رزومه...")
    text = update.message.text
    resume = f"📄 **رزومه ساخته شده**\n\n{text}\n\n✅ توسط هوش مصنوعی ساخته شد."
    await update.message.reply_text(resume)

app = Application.builder().token(TOKEN).build()

app.add_handler(CommandHandler("start", start))
app.add_handler(MessageHandler(filters.TEXT & \~filters.COMMAND, make_resume))

print("✅ بات با موفقیت شروع شد!")
app.run_polling()
